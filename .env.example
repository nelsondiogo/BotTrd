# Copie este arquivo para .env e preencha com suas credenciais
API_KEY=sua_api_key_aqui
API_SECRET=seu_api_secret_aqui
EXCHANGE_ID=binance          # binance ou bybit
SYMBOL=BTC/USDT:USDT         # Par de trading (formato CCXT para futuros)
TIMEFRAME=5m                 # Timeframe para análise (1m, 5m, 15m, 1h)
LEVERAGE=5                   # Alavancagem (1-20 recomendado)
POSITION_SIZE_PERCENT=2.0    # % do capital por operação
INITIAL_STOP_PERCENT=0.5     # Stop Loss inicial (sem lucro acumulado)
PROFIT_STOP_PERCENT=1.0      # Stop quando há lucro (% do lucro acumulado)
COOLDOWN_SECONDS=30          # Tempo de espera após fechar posição
LOOP_INTERVAL_SECONDS=10     # Intervalo do loop principal
MIN_PROFIT_TO_USE_RULE=5.0   # Lucro mínimo (USDT) para ativar regra do 1%
TESTNET=false                # true para usar testnet
